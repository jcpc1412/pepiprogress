# ─── Supabase ────────────────────────────────────────────────────────────────
# Project: pjdbxnycrvibmebfumel ("Pepiprogress")
# Copy this file to `.env` and fill in the values.
# EXPO_PUBLIC_* vars are bundled into the client — use the publishable anon key ONLY.
# Never put service_role or secret keys here.

EXPO_PUBLIC_SUPABASE_URL=https://pjdbxnycrvibmebfumel.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key-here

# ─── Google Sign-In (auth) ────────────────────────────────────────────────────
# Three separate OAuth clients in Google Cloud Console (APIs & Services →
# Credentials), all under the same project. Web is the one pasted into Supabase
# Auth → Providers → Google (client ID + secret); iOS is passed to
# GoogleSignin.configure(); Android is registered by package name + SHA-1 only
# (not referenced in JS). None of these three IDs are secrets.

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-oauth-client-id-here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-oauth-client-id-here

# ─── Terra aggregator (optional, integrations) ───────────────────────────────
# Terra credentials are SERVER-SIDE (edge secrets below) so the dev key never
# ships in the client bundle. This client flag just turns the Data Sources row on
# once those secrets are set — until then Terra shows "coming soon".

EXPO_PUBLIC_TERRA_ENABLED=false

# ─── Edge function secrets (set in Supabase dashboard, NOT here) ─────────────
# These go in: Supabase dashboard → Edge Functions → Manage secrets
#
#   ANTHROPIC_API_KEY    your-anthropic-api-key-here
#   AI_PARSE_MODEL       claude-haiku-4-5        (default)
#   AI_VISION_MODEL      claude-sonnet-4-6       (default)
#   AI_ENCOURAGE_MODEL   claude-haiku-4-5        (default)
#   AI_INSIGHTS_MODEL    claude-sonnet-4-6       (default)
#
#   TERRA_DEV_ID         your-terra-dev-id       (for the Terra integration)
#   TERRA_API_KEY        your-terra-api-key
#
# Without ANTHROPIC_API_KEY the quick-log/insights AI shows "not set up yet" and
# photo analysis / lab parsing are unavailable — the rest of the app works fully.
# Terra needs TERRA_DEV_ID + TERRA_API_KEY (edge) AND EXPO_PUBLIC_TERRA_ENABLED=true.
